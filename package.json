{
  "name": "growmodo-ai-saas",
  "version": "1.0.0",
  "packageManager": "npm@10.8.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean",
    "postinstall": "prisma generate"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "prisma": "^5.22.0",
    "turbo": "latest",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
